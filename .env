# ============================================
# LOCAL DATABASE — Prisma CLI reads this file
# ============================================
# .env is now gitignored (see .gitignore)
# Contains local PostgreSQL credentials for Prisma CLI (generate, push, migrate, studio)
# For API keys and other secrets, use .env.local instead
#
# Prisma CLI does NOT read .env.local — it only reads .env
# So DATABASE_URL must be here for commands like:
#   npx prisma db push    npx prisma migrate dev
#   npx prisma studio     npx prisma db seed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookflix
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/bookflix
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookflix
