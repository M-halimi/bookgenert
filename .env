# ============================================
# SUPABASE DATABASE — Prisma CLI reads this file
# ============================================
# Prisma CLI does NOT read .env.local — it only reads .env
# So these must be here for commands like:
#   npx prisma db push    npx prisma migrate dev
#   npx prisma studio     npx prisma db seed

# Transaction pooler (port 6543) — for Prisma RUNTIME queries
# Must include ?pgbouncer=true&connection_limit=5
DATABASE_URL=postgresql://postgres.qebzhcztktuljnnrrbza:iJs77F9ynMdHIOPr@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5

# Session pooler (port 5432) — for migrations (bypasses PgBouncer)
# Used by: prisma db push, prisma migrate dev, prisma db seed
DIRECT_URL=postgresql://postgres.qebzhcztktuljnnrrbza:iJs77F9ynMdHIOPr@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Shadow database — required for prisma migrate dev (same as DIRECT_URL)
SHADOW_DATABASE_URL=postgresql://postgres.qebzhcztktuljnnrrbza:iJs77F9ynMdHIOPr@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
