# === DATABASE (PostgreSQL — required) ===
# Neon: postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?pgbouncer=true&connection_limit=5
# Supabase: postgresql://user:password@xxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=5
DATABASE_URL=postgresql://user:password@localhost:5432/bookflix

# === AI PROVIDERS (Generation Fallback Chain) ===
# The system tries providers in order: Groq → Cloudflare → OpenRouter → HuggingFace
# If one fails (rate limit, quota, timeout), it automatically switches to the next.

# 1. Groq (primary — fastest, free tier available)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional: override default model
# GROQ_MODEL=llama-3.3-70b-versatile

# 2. Cloudflare Workers AI (mandatory backup)
# Get API token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...
# Optional: override default model
# CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# 3. OpenRouter (secondary fallback — access to many models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional: override default model
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# 4. HuggingFace (last resort — free inference API)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
# Optional: override default model
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# === LOCAL AI (optional, runs alongside the fallback chain) ===
# Ollama — local models, zero cost. Run: ollama serve
# Default model: llama3 (ollama pull llama3)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# === LEGACY PROVIDERS (still available via ApiManager for other features) ===
# These are used by mood classification, fallback router, etc.
# They are NOT in the book generation fallback chain.
# CLOUDFLARE_API_KEY=cfut_...  (use CLOUDFLARE_API_TOKEN instead)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# TOGETHER_API_KEY=...

# === API SECURITY ===
# Protect sensitive endpoints (/api/seed/*, /api/moods/backfill, /api/admin/*, /api/books/seed)
# Generate with: openssl rand -base64 32
API_SECRET_KEY=your-secret-here

# === SEARCH PROVIDERS (optional, improves book discovery) ===
# Google Books API — https://console.cloud.google.com/apis/library/books.googleapis.com
# GOOGLE_BOOKS_API_KEY=...

# === IP WHITELIST (optional, for admin endpoints) ===
# Comma-separated list of allowed IPs
# WHITELIST_IPS=203.0.113.1,203.0.113.2
