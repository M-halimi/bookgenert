# ============================================
# ENVIRONMENT VARIABLES — reference only
# ============================================
# NEVER commit real secrets to git.
#
# LOCAL DEV:   copy to .env.local   (gitignored)
# PRODUCTION:  Vercel Dashboard → Environment Variables
#
# ⚠️ SAME Supabase database for local + production.
#    Replace YOUR_PASSWORD with your Supabase DB password.
#    URL-encode the password if it contains special chars (e.g. @ → %40).

# ─────────────────────────────────────────────
# DATABASE — all environments use Supabase
# ─────────────────────────────────────────────
# Transaction pooler (port 6543) — Prisma RUNTIME queries
# Uses PgBouncer for connection pooling.
# Must include ?pgbouncer=true&connection_limit=5
# Username format: postgres.YOUR_PROJECT_REF (find ref in Supabase Dashboard → Settings)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5

# Session pooler (port 5432) — Prisma MIGRATIONS only
# Bypasses PgBouncer. Used by: prisma migrate, prisma db push
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Shadow database — required for prisma migrate dev
SHADOW_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────
# Supabase Notes
# ─────────────────────────────────────────────
# Supabase has TWO hostname types:
#
# 1. DIRECT hostname:  db.xxxxx.supabase.co  (port 5432)
#    → IPv6-ONLY (AAAA record only, no IPv4)
#    → FAILS from Vercel (IPv4-only)
#    → Use ONLY for pg_dump/psql from IPv6-capable machines
#
# 2. POOLER hostname: aws-REGION.pooler.supabase.com  (ports 6543/5432)
#    → HAS IPv4 (A record) → Works EVERYWHERE
#    → Has TWO ports:
#       - 6543 (transaction pooler) → Prisma RUNTIME
#       - 5432 (session pooler)     → Prisma MIGRATE / db push
#
# Find your pooler hostname:
#   Supabase Dashboard → Project Settings → Database →
#   Connection string → "Transaction pooler" mode

# ─────────────────────────────────────────────
# AI PROVIDERS
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...
OPENROUTER_API_KEY=sk-or-...
HUGGINGFACE_API_KEY=hf_...
GEMINI_API_KEY=...
API_SECRET_KEY=your-secret-here
