# ============================================
# ENVIRONMENT VARIABLES — copy to .env.local
# ============================================
# 1. Copy this file to .env.local
# 2. Fill in your local values
# 3. NEVER commit real secrets to git
#
# For production (Vercel + Supabase):
# Set all values in Vercel Dashboard → Project → Settings → Environment Variables
# Do NOT put production secrets in .env.example

# === DATABASE (PostgreSQL — required) ===
# LOCAL DEVELOPMENT (localhost):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookflix
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/bookflix

# PRODUCTION (Supabase + Vercel):
# Use the IPv4-compatible pooler hostname (NOT db.xxx.supabase.co which is IPv6-only):
#   Transaction pooler (runtime, port 6543):
#     postgresql://postgres:[PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres
#       ?pgbouncer=true&connection_limit=5
#   Session pooler (migrations, port 5432):
#     postgresql://postgres:[PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres
#
# ⚠️  URL-encode special characters in passwords:
#   @ → %40    # → %23    $ → %24    space → %20

# === AI PROVIDERS ===
# 1. Groq (primary — fastest)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# 2. Cloudflare Workers AI (backup)
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...

# 3. OpenRouter (secondary fallback)
OPENROUTER_API_KEY=sk-or-...

# 4. HuggingFace (last resort)
HUGGINGFACE_API_KEY=hf_...

# 5. Gemini (used by /api/generate route)
GEMINI_API_KEY=...

# === API SECURITY ===
API_SECRET_KEY=your-secret-here

# === SEARCH ===
# GOOGLE_BOOKS_API_KEY=...
