# === DATABASE (PostgreSQL — required) ===
# Prisma uses two separate connection strings with Supabase:
#   DATABASE_URL — pooled connection (port 6543 + ?pgbouncer=true) for runtime queries
#   DIRECT_URL   — direct connection (port 5432) for Prisma Migrate (avoids PgBouncer)
#
# ┌─ Supabase Pooled (DATABASE_URL) ───────────────────────────────────────┐
# │ postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres    │
# │   ?pgbouncer=true&connection_limit=5                                   │
# └────────────────────────────────────────────────────────────────────────┘
# ┌─ Supabase Direct (DIRECT_URL) ─────────────────────────────────────────┐
# │ postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres    │
# └────────────────────────────────────────────────────────────────────────┘
#
# To get these: Supabase Dashboard → Project Settings → Database → Connection string
# Select "URI" mode, then copy Pooled (port 6543) for DATABASE_URL
# and Session mode (port 5432) for DIRECT_URL.
#
# ⚠️  PASSWORD ENCODING IS CRITICAL
# If your password contains special characters (@, #, $, etc.), you MUST URL-encode them:
#   @ → %40    # → %23    $ → %24    space → %20
# WRONG: postgresql://postgres:pass@word@@db.ref.supabase.co:6543/postgres
# RIGHT: postgresql://postgres:pass%40word@db.ref.supabase.co:6543/postgres
# The @ symbol after PASSWORD must be the ONLY unencoded @ separating auth from host.
#
# Tips:
# - Replace [PASSWORD] with your database password (set during Supabase project creation)
# - Replace [REF] with your project reference ID (found in Project Settings → General)
# - Never commit real credentials — use .env.local for local dev, Vercel env vars for prod
# - If authentication fails in production: check that DATABASE_URL in Vercel has proper URL encoding
#
DATABASE_URL=postgresql://postgres:bookflix2003%40@db.pvpitwcpwzbbmmsmdtub.supabase.co:6543/postgres?pgbouncer=true&connection_limit=5
DIRECT_URL=postgresql://postgres:bookflix2003%40@db.pvpitwcpwzbbmmsmdtub.supabase.co:5432/postgres
SHADOW_DATABASE_URL=postgresql://postgres:bookflix2003%40@db.pvpitwcpwzbbmmsmdtub.supabase.co:5432/postgres

# === AI PROVIDERS (Generation Fallback Chain) ===
# The system tries providers in order: Groq → Cloudflare → OpenRouter → HuggingFace
# If one fails (rate limit, quota, timeout), it automatically switches to the next.

# 1. Groq (primary — fastest, free tier available)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional: override default model
# GROQ_MODEL=llama-3.3-70b-versatile

# 2. Cloudflare Workers AI (mandatory backup)
# Get API token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...
# Optional: override default model
# CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# 3. OpenRouter (secondary fallback — access to many models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional: override default model
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# 4. HuggingFace (last resort — free inference API)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
# Optional: override default model
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# === LOCAL AI (optional, runs alongside the fallback chain) ===
# Ollama — local models, zero cost. Run: ollama serve
# Default model: llama3 (ollama pull llama3)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# === LEGACY PROVIDERS (still available via ApiManager for other features) ===
# These are used by mood classification, fallback router, etc.
# They are NOT in the book generation fallback chain.
# CLOUDFLARE_API_KEY=cfut_...  (use CLOUDFLARE_API_TOKEN instead)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# TOGETHER_API_KEY=...

# === API SECURITY ===
# Protect sensitive endpoints (/api/seed/*, /api/moods/backfill, /api/admin/*, /api/books/seed)
# Generate with: openssl rand -base64 32
API_SECRET_KEY=your-secret-here

# === SEARCH PROVIDERS (optional, improves book discovery) ===
# Google Books API — https://console.cloud.google.com/apis/library/books.googleapis.com
# GOOGLE_BOOKS_API_KEY=...

# === IP WHITELIST (optional, for admin endpoints) ===
# Comma-separated list of allowed IPs
# WHITELIST_IPS=203.0.113.1,203.0.113.2
